#!/usr/bin/env bash
# claude-window-keeper — keep the Claude Code 5-hour window perpetually open.
# Sends "keepalive" to `claude -p` every 5 hours (just past each window's expiry).
# Logs to stdout.
# MIT licensed. https://github.com/lspahija/claude-window-keeper

set -e

interval=18060   # 5h 1m — lands just after each window expires

while true; do
  echo "[$(date -u +%FT%TZ)] pinging claude..."
  if response=$(claude -p "keepalive" </dev/null 2>&1); then
    status="ok"
  else
    status="failed"
  fi
  reply=$(printf '%s' "$response" | tr '\n' ' ' | sed 's/[[:space:]]\{1,\}/ /g; s/^ //; s/ $//')
  echo "ping $status"
  echo "claude: $reply"
  next_utc=$(date -u -r "$(($(date +%s) + interval))" +%FT%TZ 2>/dev/null \
          || date -u -d "@$(($(date +%s) + interval))" +%FT%TZ)
  echo "next ping at $next_utc"
  sleep "$interval"
done
